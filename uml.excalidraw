      "updated": 1776170458000,
      "link": null,
      "locked": false,
      "text": "TVector() - конструктор\nTVector(x, y) - конструктор со входными значениями\nget_x()\nget_y() - геттеры значений\nset_x()\nset_y() - сеттеры значений\noperator +\noperator - операторы + и - соответственно\nscalarMult - скалярное умножение векторов\nmultScalar() - умножение вектора на скаляр\nmodule() - длина вектора\nnormalize() - приведение к длине в 1",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TVector() - конструктор\nTVector(x, y) - конструктор со входными значениями\nget_x()\nget_y() - геттеры значений\nset_x()\nset_y() - сеттеры значений\noperator +\noperator - операторы + и - соответственно\nscalarMult - скалярное умножение векторов\nmultScalar() - умножение вектора на скаляр\nmodule() - длина вектора\nnormalize() - приведение к длине в 1",
      "autoResize": true,
      "lineHeight": 1.25
    },
